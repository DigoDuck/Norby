# PostgreSQL
POSTGRES_USER=norby_user
POSTGRES_PASSWORD=norby_pass
POSTGRES_DB=norby_db
POSTGRES_PORT=5432

# MongoDB
MONGO_INITDB_ROOT_USERNAME=norby_user
MONGO_INITDB_ROOT_PASSWORD=norby_pass
MONGO_PORT=27017

# Backend — JWT
SECRET_KEY=mude_para_uma_chave_segura_de_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Google Gemini
GEMINI_API_KEY=sua_chave_aqui

# URLs locais (usadas pelo backend fora do Docker)
DATABASE_URL=postgresql+asyncpg://norby_user:norby_pass@localhost:5432/norby_db
MONGODB_URL=mongodb://norby_user:norby_pass@localhost:27017